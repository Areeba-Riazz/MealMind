# Copy this file to .env and fill in your values.

# ── Firebase (get from Firebase Console → Project Settings → Your Apps → Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Backend API URL
# Leave empty in development — the Vite proxy forwards /api/* to localhost:5000
# In production set this to your deployed backend URL, e.g:
# VITE_API_URL=https://api.mealmind.app
VITE_API_URL=
