# Copy this file to .env and fill in your values.
# Get your Gemini API key from https://aistudio.google.com/app/apikey

GEMINI_API_KEY=

# Google Maps Platform API key — required for the /api/cravings endpoint.
# Enable the "Places API (New)" in your Google Cloud project and paste the key below.
# Get your key at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# Optional: set this to your deployed frontend URL in production
# e.g. FRONTEND_URL=https://mealmind.app
FRONTEND_URL=
